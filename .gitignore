# --- Secrets (NEVER commit) ---
.env
.env.local
.env.*.local

# --- Runtime output (kept via .gitkeep placeholders) ---
output/*
!output/.gitkeep
logs/*
!logs/.gitkeep

# --- Python bytecode / packaging ---
__pycache__/
*.py[cod]
*$py.class
*.egg
*.egg-info/
dist/
build/
.eggs/
wheels/
*.manifest
*.spec

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- Test / lint / type caches ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover

# --- IDE / editor ---
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# --- OS ---
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Project scratch ---
*.bak
*.tmp
.scratch/

# --- Git worktrees ---
.worktrees/
